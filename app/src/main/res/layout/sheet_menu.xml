<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/toolbar_bg"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="Menu"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Row 1 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout android:id="@+id/menuAddBookmark"
            style="@style/MenuItemStyle">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_bookmark" android:tint="@color/colorPrimary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Bookmark" style="@style/MenuLabelStyle" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menuBookmarks"
            style="@style/MenuItemStyle">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_bookmarks" android:tint="@color/icon_color" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Bookmarks" style="@style/MenuLabelStyle" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menuHistory"
            style="@style/MenuItemStyle">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_history" android:tint="@color/icon_color" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="History" style="@style/MenuLabelStyle" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menuShare"
            style="@style/MenuItemStyle">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_share" android:tint="@color/icon_color" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Share" style="@style/MenuLabelStyle" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout android:id="@+id/menuDesktop"
            style="@style/MenuItemStyle">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_desktop" android:tint="@color/icon_color" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Desktop" style="@style/MenuLabelStyle" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menuAdblock"
            style="@style/MenuItemStyle">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_shield" android:tint="@color/colorPrimary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ad Block" style="@style/MenuLabelStyle" />
        </LinearLayout>

        <LinearLayout android:id="@+id/menuSettings"
            style="@style/MenuItemStyle">
            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                android:src="@drawable/ic_settings" android:tint="@color/icon_color" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Settings" style="@style/MenuLabelStyle" />
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="80dp"
            android:layout_weight="1" />
    </LinearLayout>
</LinearLayout>
